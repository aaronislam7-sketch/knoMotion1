{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SideBySideCompare",
  "description": "Left vs right comparison blocks with text, icons, and animated reveals. Uses SDK Card and Text elements.",
  "type": "object",
  "required": ["beats"],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["standard", "beforeAfter"],
      "default": "standard",
      "description": "Comparison mode. 'standard': left/right text comparison. 'beforeAfter': image slider comparison with clip-path reveal."
    },
    "left": {
      "type": "object",
      "description": "Left side configuration",
      "properties": {
        "title": {
          "type": "string",
          "description": "Main title for left side"
        },
        "subtitle": {
          "type": "string",
          "description": "Subtitle or description"
        },
        "icon": {
          "type": "string",
          "description": "Emoji or icon"
        },
        "items": {
          "type": "array",
          "description": "List of bullet points",
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "properties": {
                  "text": { "type": "string" },
                  "icon": { "type": "string" }
                }
              }
            ]
          }
        },
        "color": {
          "type": "string",
          "description": "Accent color for this side"
        },
        "backgroundColor": {
          "type": "string",
          "description": "Background color for content area"
        }
      }
    },
    "right": {
      "type": "object",
      "description": "Right side configuration (same structure as left)",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "icon": { "type": "string" },
        "items": { "type": "array" },
        "color": { "type": "string" },
        "backgroundColor": { "type": "string" }
      }
    },
    "animation": {
      "type": "string",
      "enum": ["slide", "fade", "scale", "bounce", "reveal"],
      "default": "slide",
      "description": "Animation type for side reveals"
    },
    "staggerDelay": {
      "type": "number",
      "default": 0.3,
      "minimum": 0,
      "description": "Delay between sides in seconds"
    },
    "animationDuration": {
      "type": "number",
      "default": 0.6,
      "minimum": 0.1,
      "description": "Animation duration per side in seconds"
    },
    "dividerType": {
      "type": "string",
      "enum": ["none", "line", "dashed", "vs"],
      "default": "vs",
      "description": "Style of center divider. 'vs': circular badge with VS text."
    },
    "dividerLabel": {
      "type": "string",
      "default": "VS",
      "description": "Label text for VS badge"
    },
    "dividerColor": {
      "type": "string",
      "default": "primary",
      "description": "Divider color. Theme keys: primary, secondary, accentGreen. Or hex/rgb."
    },
    "alignment": {
      "type": "string",
      "enum": ["center", "inner"],
      "default": "center",
      "description": "Content alignment. 'center': both sides centered. 'inner': content faces the divider."
    },
    "before": {
      "type": "object",
      "description": "Before-state config (only used when mode is 'beforeAfter')",
      "properties": {
        "title": {
          "type": "string",
          "description": "Overlay label for the before state"
        },
        "media": {
          "type": "object",
          "description": "Media content for the before state",
          "properties": {
            "image": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "object",
                  "properties": {
                    "src": { "type": "string" },
                    "alt": { "type": "string" },
                    "fit": { "type": "string", "enum": ["cover", "contain"] },
                    "borderRadius": { "type": "number" },
                    "style": { "type": "object" }
                  },
                  "required": ["src"]
                }
              ]
            },
            "lottie": { "type": "string", "description": "Lottie registry key or URL" }
          }
        }
      }
    },
    "after": {
      "type": "object",
      "description": "After-state config (only used when mode is 'beforeAfter')",
      "properties": {
        "title": {
          "type": "string",
          "description": "Overlay label for the after state"
        },
        "media": {
          "type": "object",
          "description": "Media content for the after state",
          "properties": {
            "image": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "object",
                  "properties": {
                    "src": { "type": "string" },
                    "alt": { "type": "string" },
                    "fit": { "type": "string", "enum": ["cover", "contain"] },
                    "borderRadius": { "type": "number" },
                    "style": { "type": "object" }
                  },
                  "required": ["src"]
                }
              ]
            },
            "lottie": { "type": "string", "description": "Lottie registry key or URL" }
          }
        }
      }
    },
    "slider": {
      "type": "object",
      "description": "Slider configuration for beforeAfter mode",
      "properties": {
        "autoAnimate": {
          "type": "boolean",
          "default": true,
          "description": "Whether the slider animates automatically"
        },
        "from": {
          "type": "number",
          "default": 0.05,
          "minimum": 0,
          "maximum": 1,
          "description": "Starting position of the slider (0-1)"
        },
        "to": {
          "type": "number",
          "default": 1.0,
          "minimum": 0,
          "maximum": 1,
          "description": "Ending position of the slider (0-1)"
        },
        "initial": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Initial slider position before animation starts"
        },
        "beats": {
          "type": "object",
          "properties": {
            "start": { "type": "number", "description": "When the slider animation starts (seconds)" },
            "exit": { "type": "number", "description": "When the slider animation ends (seconds)" }
          }
        }
      }
    },
    "beats": {
      "type": "object",
      "required": ["start"],
      "properties": {
        "start": {
          "type": "number",
          "description": "Start time in seconds"
        },
        "hold": {
          "type": "number",
          "description": "Hold duration in seconds"
        },
        "exit": {
          "type": "number",
          "description": "Exit time in seconds"
        }
      }
    },
    "position": {
      "type": "object",
      "description": "Slot position from layout resolver",
      "properties": {
        "left": { "type": "number" },
        "top": { "type": "number" },
        "width": { "type": "number" },
        "height": { "type": "number" }
      }
    },
    "style": {
      "type": "object",
      "description": "Optional style overrides",
      "properties": {
        "container": { "type": "object" },
        "sideWrapper": { "type": "object" },
        "sideContent": { "type": "object" },
        "icon": { "type": "object" },
        "title": { "type": "object" },
        "subtitle": { "type": "object" },
        "itemsList": { "type": "object" },
        "item": { "type": "object" },
        "itemText": { "type": "object" },
        "dividerWrapper": { "type": "object" },
        "dividerLine": { "type": "object" },
        "vsBadge": { "type": "object" },
        "vsText": { "type": "object" }
      }
    }
  },
  "examples": [
    {
      "left": {
        "title": "Before",
        "icon": "😕",
        "items": [
          "Confusing syntax",
          "Hard to debug",
          "Slow performance"
        ],
        "color": "secondary"
      },
      "right": {
        "title": "After",
        "icon": "🎉",
        "items": [
          "Clean code",
          "Easy debugging",
          "Lightning fast"
        ],
        "color": "accentGreen"
      },
      "animation": "slide",
      "dividerType": "vs",
      "beats": { "start": 1.0 }
    },
    {
      "left": {
        "title": "Option A",
        "subtitle": "Traditional approach",
        "icon": "📚",
        "items": [
          { "text": "Well-documented", "icon": "✓" },
          { "text": "Proven track record", "icon": "✓" }
        ],
        "backgroundColor": "pageBg"
      },
      "right": {
        "title": "Option B",
        "subtitle": "Modern solution",
        "icon": "🚀",
        "items": [
          { "text": "Cutting-edge features", "icon": "✓" },
          { "text": "Better scalability", "icon": "✓" }
        ],
        "backgroundColor": "pageBg"
      },
      "animation": "reveal",
      "dividerType": "dashed",
      "staggerDelay": 0.4,
      "beats": { "start": 0.5 }
    },
    {
      "mode": "beforeAfter",
      "before": {
        "title": "Before",
        "media": {
          "image": { "src": "https://example.com/before.jpg", "fit": "cover", "borderRadius": 28 }
        }
      },
      "after": {
        "title": "After",
        "media": {
          "image": { "src": "https://example.com/after.jpg", "fit": "cover", "borderRadius": 28 }
        }
      },
      "slider": {
        "autoAnimate": true,
        "from": 0.05,
        "to": 0.95,
        "beats": { "start": 1.5, "exit": 7.0 }
      },
      "beats": { "start": 0.5, "hold": 4.8, "exit": 10.0 }
    }
  ],
  "useCase": {
    "description": "Side-by-side comparison for before/after, pros/cons, or A vs B scenarios",
    "when": "Use when comparing two options, showing transformation, or contrasting concepts",
    "layout": "Two equal columns with optional VS divider in center"
  },
  "sizingBehavior": {
    "description": "SideBySideCompare splits the slot into two equal halves",
    "width": "Each side uses 50% of slot width",
    "height": "Content is vertically centered within full slot height",
    "fontScaling": "Base font size scales with slot height (16-28px range)",
    "divider": "VS badge sized relative to font size, with connecting lines spanning 25% of height each"
  }
}
